import configparser
import os
import shutil
import signal
import shlex
import socket
import subprocess
import sys
import time
import warnings
from pathlib import Path

warnings.filterwarnings("ignore", category=DeprecationWarning)

BUS_NAME = "org.armada.Power"
OBJECT_PATH = "/org/armada/Power"
IFACE = "org.armada.Power1"
PROFILES = ["eco", "balanced", "performance"]
STATE_FILE = Path("/var/lib/armada/powerd.state")
FACTORY_CONFIG_FILE = Path("/usr/share/armada/power-profiles.conf")
CONFIG_FILE = Path("/etc/armada/power-profiles.conf")
FAN_SAFE_PWM = 128


def normalize_profile(profile):
    value = profile.strip().lower()
    return value if value in PROFILES else ""


