#!/usr/bin/bash
set -euo pipefail

[[ ${XDG_SESSION_TYPE:-} == wayland ]] || exit 0

activation_env=(
    DESKTOP_SESSION
    XDG_CURRENT_DESKTOP
    XDG_SESSION_DESKTOP
    XDG_SESSION_TYPE
    WAYLAND_DISPLAY
    DISPLAY
    XAUTHORITY
    KDE_FULL_SESSION
    KDE_SESSION_VERSION
)
if command -v dbus-update-activation-environment >/dev/null 2>&1; then
    dbus-update-activation-environment --systemd "${activation_env[@]}" 2>/dev/null || true
else
    systemctl --user import-environment "${activation_env[@]}" 2>/dev/null || true
fi

config_dir="${XDG_CONFIG_HOME:-${HOME}/.config}/armada"
rotation_done="${config_dir}/desktop-rotation.done"
scale_done="${config_dir}/desktop-scale.done"
dual_done="${config_dir}/desktop-dualscreen.done"

[[ ! -e "${rotation_done}" || ! -e "${scale_done}" || ! -e "${dual_done}" ]] || exit 0
mkdir -p "${config_dir}"

if command -v /usr/libexec/armada/device-env >/dev/null 2>&1; then
    eval "$(/usr/libexec/armada/device-env)"
fi

display_connector="${ARMADA_PRIMARY_CONNECTOR:-}"
panel_orientation="${ARMADA_PANEL_ORIENTATION:-normal}"

[[ -n "${display_connector}" ]] || exit 0

for _ in {1..5}; do
    kscreen-doctor -o >/dev/null 2>&1 && break
    sleep 2
done

if [[ ! -e "${rotation_done}" ]]; then
    case "${panel_orientation}" in
        left|right|inverted)
            if kscreen-doctor "output.${display_connector}.rotation.${panel_orientation}" >/dev/null 2>&1; then
                touch "${rotation_done}"
            fi
            ;;
        *)
            touch "${rotation_done}"
            ;;
    esac
fi

if [[ ! -e "${scale_done}" ]] && kscreen-doctor "output.${display_connector}.scale.1.5" >/dev/null 2>&1; then
    touch "${scale_done}"
fi

if [[ ! -e "${dual_done}" ]]; then
    if [[ -z "${ARMADA_SECONDARY_CONNECTOR:-}" ]]; then
        touch "${dual_done}"
    elif /usr/libexec/armada/setup-dual-screen; then
        touch "${dual_done}"
    fi
fi
