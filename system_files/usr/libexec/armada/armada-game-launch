#!/usr/bin/env python3
# Game launch-option prefix wrapper ("armada-game-launch %command%"). Applies
# per-game settings via FEX_APP_CONFIG, the only knob every compat tool's FEX reads
# (the on-disk FEX config files are seen only by the system FEX, not arm64ec/wow64).
import json
import os
import pathlib
import shutil
import sys
import time


BASE_FEX_CONFIG = pathlib.Path("/usr/share/fex-emu/Config.json")
TWEAKS_CONFIG = pathlib.Path("/etc/armada/game-tweaks.json")
FEX_PROFILES_CONFIG = pathlib.Path("/usr/share/armada/fex-profiles.json")
PROTON_INJECT_SRC = pathlib.Path("/usr/share/armada/proton-inject/x86_64-linux-gnu")


def appid():
    for key in ("STEAM_COMPAT_APP_ID", "SteamAppId", "SteamGameId"):
        value = os.environ.get(key, "").strip()
        if value.isdigit():
            return value
    return None


def load_fex_contract():
    with FEX_PROFILES_CONFIG.open(encoding="utf-8") as f:
        contract = json.load(f)
    profiles = contract.get("profiles")
    if not isinstance(contract.get("defaults"), dict) or not isinstance(profiles, dict) or "default" not in profiles:
        raise ValueError("invalid FEX profile contract")
    for profile in profiles.values():
        if not isinstance(profile, dict) or not isinstance(profile.get("config"), dict):
            raise ValueError("invalid FEX profile contract")
    return contract


def load_tweaks(defaults):
    data = json.loads(json.dumps(defaults))
    try:
        with TWEAKS_CONFIG.open(encoding="utf-8") as f:
            loaded = json.load(f)
    except (OSError, ValueError):
        return data
    if not isinstance(loaded, dict):
        return data
    if isinstance(loaded.get("global"), dict):
        data["global"].update(loaded["global"])
    if isinstance(loaded.get("games"), dict):
        data["games"] = loaded["games"]
    return data


def merged_settings(tweaks, game_id):
    settings = dict(tweaks.get("global", {}))
    if game_id:
        game_settings = tweaks.get("games", {}).get(str(game_id))
        # Legacy configs may carry enabled: false; skip those, apply the rest.
        if isinstance(game_settings, dict) and game_settings.get("enabled") is not False:
            settings.update(game_settings)
    return settings


def thunk_settings(settings, modules):
    thunks = settings.get("thunks")
    if not isinstance(thunks, dict):
        thunks = {}
    return {name: 1 if thunks.get(name, True) else 0 for name in modules}


def runtime_config_dir():
    runtime = os.environ.get("XDG_RUNTIME_DIR")
    if runtime:
        return pathlib.Path(runtime) / "armada-fex"
    return pathlib.Path("/tmp") / f"armada-fex-{os.getuid()}"


def resolve_fex_config(settings, profiles):
    profile_id = settings.get("fexProfile")
    if isinstance(profile_id, str) and profile_id in profiles:
        return profiles[profile_id]["config"]
    fex_config = settings.get("fexConfig")
    if isinstance(fex_config, dict):
        return fex_config
    return profiles["default"]["config"]


def apply_fex(settings, game_id, profiles, env):
    with BASE_FEX_CONFIG.open(encoding="utf-8") as f:
        config = json.load(f)
    allowed = set().union(*(profile["config"].keys() for profile in profiles.values()))
    fex_config = resolve_fex_config(settings, profiles)
    config.setdefault("Config", {}).update({k: v for k, v in fex_config.items() if k in allowed})
    config["ThunksDB"] = thunk_settings(settings, config.get("ThunksDB", {}).keys())

    config_dir = runtime_config_dir()
    config_dir.mkdir(mode=0o700, parents=True, exist_ok=True)
    cutoff = time.time() - 86400
    for old in config_dir.glob("*.json"):
        try:
            if old.stat().st_mtime < cutoff:
                old.unlink()
        except OSError:
            pass
    name = f"{game_id or 'global'}.{os.getpid()}.json"
    target = config_dir / name
    tmp = target.with_name(f".{name}.tmp")
    try:
        with tmp.open("w", encoding="utf-8") as f:
            json.dump(config, f, indent=2, sort_keys=True)
            f.write("\n")
        os.replace(tmp, target)
        env["FEX_APP_CONFIG"] = str(target)
    finally:
        tmp.unlink(missing_ok=True)


def inject_x86_protocol_libs():
    # pressure-vessel doesn't provide the x86 libwayland-client/libxkbcommon the game
    # needs, so it can't load them (dead controller). Remove once pressure-vessel supplies
    # them.
    if not PROTON_INJECT_SRC.is_dir():
        return
    for tool in os.environ.get("STEAM_COMPAT_TOOL_PATHS", "").split(":"):
        files = pathlib.Path(tool) / "files" if tool else None
        if files is None:
            continue
        lib_dir = files / "lib" / "x86_64-linux-gnu"
        if not lib_dir.is_dir() or (files / "bin-arm64").is_dir():  # skip arm64ec Proton
            continue
        # link targets must be copied before the symlinks that point at them
        for src in sorted(PROTON_INJECT_SRC.iterdir(), key=pathlib.Path.is_symlink):
            dest = lib_dir / src.name
            if dest.exists() or dest.is_symlink():
                continue
            if src.is_symlink():
                os.symlink(os.readlink(src), dest)
            else:
                shutil.copy2(src, dest)


def repair_wedged_controller():
    # x86 Proton can leave the pad registered as a bare USB device, never promoted to
    # WINEXINPUT (dead under x86 too); an arm64ec Proton reusing that prefix then can't
    # re-register it - winebus hits "already exists" (plugplay 0xe000020b) - and inherits
    # the dead pad. Drop the stale VID_28DE sections to re-register.
    data_path = os.environ.get("STEAM_COMPAT_DATA_PATH")
    if not data_path:
        return
    reg = pathlib.Path(data_path) / "pfx" / "system.reg"
    try:
        text = reg.read_text(encoding="utf-8", errors="surrogateescape")
    except FileNotFoundError:
        return
    lines = text.splitlines(keepends=True)
    pad_sections = sum(1 for line in lines if line.startswith("[") and "VID_28DE" in line)
    if not pad_sections or any("WINEXINPUT" in line for line in lines):
        return  # no pad registered, or it promoted fine - leave the prefix alone
    reg.with_name("system.reg.armada-bak").write_text(
        text, encoding="utf-8", errors="surrogateescape")
    kept, skip = [], False
    for line in lines:
        if line.startswith("["):
            skip = "VID_28DE" in line
        if not skip:
            kept.append(line)
    tmp = reg.with_name(".system.reg.armada-tmp")
    tmp.write_text("".join(kept), encoding="utf-8", errors="surrogateescape")
    os.replace(tmp, reg)
    print(f"armada-game-launch: cleared wedged controller state "
          f"({pad_sections} pad sections)", file=sys.stderr)


def main():
    args = sys.argv[1:]
    if not args:
        raise SystemExit("usage: armada-game-launch COMMAND [ARGS...]")

    # Proton-CachyOS enables its shader compiler HUD unless DXVK_HUD is already
    # set. Keep Armada's default clean while preserving an explicit user HUD.
    os.environ.setdefault("DXVK_HUD", "none")

    game_id = appid()
    try:
        contract = load_fex_contract()
        settings = merged_settings(load_tweaks(contract["defaults"]), game_id)
        apply_fex(settings, game_id, contract["profiles"], os.environ)
    except Exception as exc:
        print(f"armada-game-launch: failed to apply settings: {exc}", file=sys.stderr)

    try:
        inject_x86_protocol_libs()
    except Exception as exc:
        print(f"armada-game-launch: protocol-lib inject skipped: {exc}", file=sys.stderr)

    try:
        repair_wedged_controller()
    except Exception as exc:
        print(f"armada-game-launch: controller repair skipped: {exc}", file=sys.stderr)

    try:
        os.execv(args[0], args)
    except OSError as exc:
        raise SystemExit(f"armada-game-launch: failed to exec game: {exc}")


if __name__ == "__main__":
    main()
