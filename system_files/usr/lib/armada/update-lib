#!/bin/bash
# Shared helpers for the armada update hooks (steamos-update, steamos-select-branch).

ARMADA_REGISTRY="ghcr.io/virtudude/armada"
ARMADA_CHANNEL_STATE="/var/lib/armada/update-channel"
ARMADA_CHANNELS="stable beta testing"

# Steam's picker speaks Valve's branch tokens; translate to/from our ghcr tags.
armada_token_to_channel() {
    case "$1" in
        rel|latest|stable) echo stable ;;
        beta)               echo beta ;;
        rc|bc|main|preview|testing) echo testing ;;
        *) return 1 ;;
    esac
}
armada_channel_to_token() {
    case "$1" in
        beta)    echo beta ;;
        testing) echo preview ;;
        *)       echo rel ;;
    esac
}

# Tag from a container ref, stripping any @digest and transport/registry prefix.
armada_tag_from_ref() {
    local r="${1%@*}"; r="${r##*/}"
    [[ "$r" == *:* ]] && echo "${r##*:}" || echo ""
}

# Raw container-image-reference of the booted deployment. rpm-ostree works
# unprivileged (bootc status needs root), so the -c query can call this.
armada_booted_ref() {
    rpm-ostree status --booted --json 2>/dev/null | python3 -c \
        'import sys,json; d=json.load(sys.stdin).get("deployments") or [{}]; print(d[0].get("container-image-reference",""))' 2>/dev/null || true
}
armada_booted_channel() { armada_tag_from_ref "$(armada_booted_ref)"; }

# Raw image ref of the staged (next-boot) deployment, if any. Needs root.
armada_staged_ref() {
    bootc status --format json 2>/dev/null | python3 -c \
        'import sys,json; st=json.load(sys.stdin).get("status",{}).get("staged"); print(st["image"]["image"]["image"] if st else "")' 2>/dev/null || true
}

# Channel the user selected, validated to a known channel; else $1 (a caller-
# supplied booted channel, to avoid re-querying) or the booted channel.
armada_desired_channel() {
    local c="" ch
    [[ -r "$ARMADA_CHANNEL_STATE" ]] && read -r c < "$ARMADA_CHANNEL_STATE" 2>/dev/null
    # Exact-match a known channel (a substring/glob test would accept a corrupt
    # multi-word value and feed it to bootc as a tag).
    for ch in ${ARMADA_CHANNELS}; do
        [[ "$c" == "$ch" ]] && { echo "$c"; return; }
    done
    if [[ -n "${1:-}" ]]; then echo "$1"; else armada_booted_channel; fi
}

# Run a bootc command with progress wired to the Steam N% translator. fd 3 must
# be a pipe; use a 0700 tmpdir so the FIFO can't be pre-created by another user.
armada_bootc_with_progress() {
    local dir rc reader
    dir="$(mktemp -d 2>/dev/null)" || { "$@" 1>&2; return $?; }
    mkfifo "$dir/p" 2>/dev/null || { rm -rf "$dir"; "$@" 1>&2; return $?; }
    /usr/libexec/armada/update-progress < "$dir/p" &
    reader=$!
    # bootc's own stdout -> stderr; only the translator's N% reaches Steam.
    "$@" --progress-fd 3 3>"$dir/p" 1>&2; rc=$?
    wait "$reader" 2>/dev/null
    rm -rf "$dir"
    return "$rc"
}
